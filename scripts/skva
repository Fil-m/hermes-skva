#!/usr/bin/env python3
"""
SKVA — Система Колективної Взаємодії Агентів.
Команди: skva solo "запит" [директорія]
         skva rada-fabryka "запит"
         skva doctor
         skva test
"""
import sys, os, time, json
from pathlib import Path

# Додаємо scripts в PATH
SCRIPT_DIR = Path(__file__).parent
sys.path.insert(0, str(SCRIPT_DIR))

def cmd_solo(request, project_dir="."):
    """Solo method — async, JSON output, Python creates files."""
    import asyncio
    from skva_core import solo as solo_async
    return asyncio.run(solo_async(request, project_dir))

def cmd_rada_fabryka(request, project_dir="."):
    """Rada+Fabryka — async parallel + auto-fix loop."""
    import asyncio
    from skva_core import rada_fabryka
    return asyncio.run(rada_fabryka(request, project_dir))

def cmd_doctor():
    """Діагностика системи."""
    checks = []
    
    import subprocess
    r = subprocess.run(["hermes", "--version"], capture_output=True, text=True)
    checks.append(("Hermes", r.returncode == 0, r.stdout.strip()[:50] if r.returncode == 0 else "not found"))
    
    r = subprocess.run(["hermes", "skills", "list"], capture_output=True, text=True)
    has_orch = "orchestrator" in r.stdout
    checks.append(("SKVA skills", has_orch, "orchestrator found" if has_orch else "not installed"))
    
    r = subprocess.run(["git", "--version"], capture_output=True, text=True)
    checks.append(("Git", r.returncode == 0, r.stdout.strip()))
    
    checks.append(("Python", True, sys.version.split()[0]))
    
    import shutil
    total, used, free = shutil.disk_usage("/tmp")
    free_gb = free // (2**30)
    checks.append(("Disk space", free_gb > 1, f"{free_gb}GB free"))
    
    print("\n=== SKVA Doctor ===")
    for name, ok, msg in checks:
        icon = "✅" if ok else "❌"
        print(f"  {icon} {name}: {msg}")
    print()
    
    all_ok = all(c[1] for c in checks)
    if all_ok:
        print("✅ Все готово до роботи")
    else:
        print("⚠️ Є проблеми, виправ перед запуском")
    return all_ok

def cmd_test():
    """Smoke test."""
    print("=== SKVA Test ===")
    
    print("\n1. Перевірка Hermes...")
    import subprocess
    r = subprocess.run(["hermes", "chat", "-q", "say OK"], capture_output=True, text=True, timeout=30)
    if "OK" in r.stdout:
        print("   ✅ Hermes відповідає")
    else:
        print("   ❌ Hermes не відповідає")
        return False
    
    print("\n2. Solo метод (створення файлу)...")
    test_dir = f"/tmp/skva-test-{int(time.time())}"
    ok = cmd_solo("create a file test.txt in artifacts/fullstack/ with content HELLO", test_dir)
    print(f"   {'✅' if ok else '❌'} Solo")
    
    test_file = f"{test_dir}/.hermes/artifacts/fullstack/test.txt"
    if os.path.exists(test_file):
        print(f"   ✅ test.txt створено")
    else:
        found = list(Path(test_dir).rglob("*"))
        print(f"   ⚠️ test.txt не знайдено. Файли: {[str(f.relative_to(test_dir)) for f in found[:5]]}")
    
    print(f"\n=== Тест завершено ===")
    return ok

def main():
    if len(sys.argv) < 2:
        print("SKVA — Система Колективної Взаємодії Агентів Hermes")
        print()
        print("Використання:")
        print("  skva solo \"запит\" [директорія]  — Solo метод")
        print("  skva rada \"запит\"             — Rada+Fabryka")
        print("  skva doctor                    — діагностика")
        print("  skva test                      — smoke test")
        print()
        print("Приклад:")
        print("  skva solo \"створи index.html з Hello World\"")
        print("  skva doctor")
        return
    
    cmd = sys.argv[1]
    
    if cmd == "solo":
        request = sys.argv[2] if len(sys.argv) > 2 else "create a test file"
        proj = sys.argv[3] if len(sys.argv) > 3 else f"/tmp/skva-{int(time.time())}"
        cmd_solo(request, proj)
    elif cmd == "rada":
        request = sys.argv[2] if len(sys.argv) > 2 else "new project"
        proj = sys.argv[3] if len(sys.argv) > 3 else f"/tmp/skva-{int(time.time())}"
        cmd_rada_fabryka(request, proj)
    elif cmd == "doctor":
        cmd_doctor()
    elif cmd == "test":
        cmd_test()
    else:
        print(f"Невідома команда: {cmd}")
        print("Команди: solo, rada, doctor, test")

if __name__ == "__main__":
    main()
