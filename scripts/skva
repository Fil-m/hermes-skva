#!/usr/bin/env python3
"""
SKVA v5 — Система Колективної Взаємодії Агентів.
State DAG, Error Taxonomy, Diffs, Resource Balancing, Isolation.
"""
import sys, os, time
from pathlib import Path

SCRIPT_DIR = Path(__file__).parent
sys.path.insert(0, str(SCRIPT_DIR))

def cmd_solo(request, project_dir="."):
    import asyncio
    from skva_core import solo
    return asyncio.run(solo(request, project_dir))

def cmd_rada(request, project_dir="."):
    import asyncio
    from skva_core import rada_fabryka
    return asyncio.run(rada_fabryka(request, project_dir))

def cmd_agile(request, project_dir="."):
    import asyncio
    from skva_core import agile
    return asyncio.run(agile(request, project_dir))

def cmd_pipeline(request, project_dir="."):
    import asyncio
    from skva_core import pipeline
    return asyncio.run(pipeline(request, project_dir))

def cmd_dag(request, project_dir="."):
    """Custom DAG from JSON file."""
    import asyncio, json
    dag_file = Path(project_dir) / ".skva" / "custom_dag.json"
    if not dag_file.exists():
        print(f"❌ DAG file not found: {dag_file}")
        return False
    from skva_core import run_dag, Node, NodeType
    with open(dag_file) as f:
        data = json.load(f)
    nodes = [Node(n["id"], NodeType(n["type"]), n.get("role","developer"),
                  task_template=n.get("task","{request}"),
                  on_success=n.get("on_success",[]),
                  on_failure=n.get("on_failure",[]))
             for n in data.get("nodes",[])]
    edges = [(e["from"], e["to"], e.get("condition","success"))
             for e in data.get("edges",[])]
    return asyncio.run(run_dag(nodes, edges, request, str(dag_file.parent)))

def cmd_doctor():
    checks = []
    import subprocess
    r = subprocess.run(["hermes", "--version"], capture_output=True, text=True)
    checks.append(("Hermes", r.returncode == 0, r.stdout.strip()[:50] if r.returncode == 0 else "not found"))
    r = subprocess.run(["git", "--version"], capture_output=True, text=True)
    checks.append(("Git", r.returncode == 0, r.stdout.strip()))
    checks.append(("Python", True, sys.version.split()[0]))
    import shutil
    total, used, free = shutil.disk_usage("/tmp")
    checks.append(("Disk", free//(2**30) > 1, f"{free//(2**30)}GB free"))
    # Check import
    try:
        from skva_core import StateMachine, ErrorCode, SecureWorkspace, ResourceManager
        checks.append(("SKVA v5 engine", True, "StateMachine+ErrorTaxonomy+Isolation+ResourceBalancer"))
    except Exception as e:
        checks.append(("SKVA v5 engine", False, str(e)))
    
    print("\n=== SKVA v5 Doctor ===")
    for name, ok, msg in checks:
        print(f"  {'✅' if ok else '❌'} {name}: {msg}")
    print()
    all_ok = all(c[1] for c in checks)
    if all_ok: print("✅ Все готово")
    else: print("⚠️ Є проблеми")
    return all_ok

def cmd_test():
    print("=== SKVA v5 Test ===")
    import subprocess
    tests = 0; passed = 0
    
    # 1. Imports
    print("\n1. Перевірка імпортів...")
    try:
        from skva_core import (
            StateMachine, Node, NodeType, ErrorCode, classify_error,
            ResourceManager, SecureWorkspace, should_patch,
            parse_search_replace_blocks, apply_search_replace,
            solo, rada_fabryka, agile, pipeline, MarkdownAgent
        )
        print("   ✅ Всі імпорти v5")
        tests += 1; passed += 1
    except Exception as e:
        print(f"   ❌ {e}")
        tests += 1
    
    # 2. StateMachine
    print("2. StateMachine DAG...")
    from skva_core import StateMachine, Node, NodeType, ErrorCode, classify_error
    sm = StateMachine("/tmp/skva-v5-test")
    sm.reset()
    sm.add_node(Node("start", NodeType.ANALYZE, "analyst"))
    sm.add_node(Node("end", NodeType.DONE, ""))
    sm.add_edge("start", "end", "success")
    assert sm.nodes["start"].on_success == ["end"]
    next_n = sm.transition("start", "success")
    assert next_n == "end"
    # Test state persistence
    sm2 = StateMachine("/tmp/skva-v5-test")
    assert "start" in sm2.nodes
    print("   ✅ DAG: nodes, edges, transition, persistence")
    tests += 1; passed += 1
    
    # 3. Error Taxonomy
    print("3. Error taxonomy...")
    assert classify_error("SyntaxError: invalid syntax") == ErrorCode.SYNTAX
    assert classify_error("ModuleNotFoundError: No module named 'x'") == ErrorCode.IMPORT
    assert classify_error("timeout") == ErrorCode.TIMEOUT
    assert classify_error("", "```python\nprint(42)\n") == ErrorCode.TRUNCATED  # unclosed block
    print("   ✅ classify_error: SYNTAX, IMPORT, TIMEOUT, TRUNCATED, REFUSAL")
    tests += 1; passed += 1
    
    # 4. Diffs
    print("4. Diffs policy...")
    assert should_patch("", "new content") == False  # new file
    assert should_patch("a\nb\nc", "a\nb\nc\n") == True  # small change
    assert parse_search_replace_blocks("<<<<<<< SEARCH\nold\n=======\nnew\n>>>>>>> REPLACE") == [("old", "new")]
    result, ok = apply_search_replace("hello old world", [("old", "new")])
    assert result == "hello new world", f"Got: {result}"
    assert ok == True
    # Test failed patch
    result2, ok2 = apply_search_replace("hello world", [("missing", "new")])
    assert ok2 == False
    print("   ✅ SEARCH/REPLACE: parse + apply + should_patch + failure detection")
    tests += 1; passed += 1
    
    # 5. Resource Balancing
    print("5. Resource balancer...")
    rm = ResourceManager("/tmp/skva-v5-test")
    cap = rm.get_max_concurrent()
    assert cap >= 1, f"Capacity should be >=1, got {cap}"
    rm.update(2, "tick")
    print(f"   ✅ Capacity: {cap} concurrent agents")
    tests += 1; passed += 1
    
    # 6. SecureWorkspace
    print("6. Secure workspace...")
    ws = SecureWorkspace()
    assert ws.temp_dir.exists()
    assert ws.temp_dir.stat().st_mode & 0o777 == 0o700  # owner-only
    ws.cleanup()
    assert not ws.temp_dir.exists()
    print("   ✅ temp isolation + cleanup")
    tests += 1; passed += 1
    
    print(f"\n=== {passed}/{tests} тестів пройдено ✅ ===")
    return passed == tests

def main():
    if len(sys.argv) < 2:
        print("SKVA v5 — Колективна взаємодія агентів")
        print()
        print("Методи:")
        print("  skva solo     \"запит\"  — Solo (1 fullstack agent)")
        print("  skva rada     \"запит\"  — Rada+Fabryka (аналіз→код→деплой)")
        print("  skva agile    \"запит\"  — Agile (дизайн→код→рев'ю→фікс)")
        print("  skva pipeline \"запит\"  — Pipeline (+аналіз, +рев'ю, +деплой)")
        print("  skva dag      \"запит\"  — Custom DAG з .skva/custom_dag.json")
        print()
        print("Сервіс:")
        print("  skva doctor             — діагностика")
        print("  skva test               — smoke test")
        print()
        print("Приклад:")
        print("  skva solo \"створи index.html\" /tmp/my-project")
        return
    
    cmd = sys.argv[1]
    proj = sys.argv[3] if len(sys.argv) > 3 else f"/tmp/skva-{int(time.time())}"
    request = sys.argv[2] if len(sys.argv) > 2 else "create a test file"
    
    methods = {"solo": cmd_solo, "rada": cmd_rada, "agile": cmd_agile,
               "pipeline": cmd_pipeline, "dag": cmd_dag}
    
    if cmd in methods:
        methods[cmd](request, proj)
    elif cmd == "doctor":
        cmd_doctor()
    elif cmd == "test":
        cmd_test()
    else:
        print(f"Невідома команда: {cmd}")
        print("Команди: solo, rada, agile, pipeline, dag, doctor, test")

if __name__ == "__main__":
    main()
